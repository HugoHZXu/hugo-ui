{
  "name": "@hugo-ui/mui",
  "version": "1.0.2",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/theme": {
      "types": "./dist/styles/theme.d.ts",
      "import": "./dist/styles/theme.js"
    },
    "./utils/wcagUtils": {
      "types": "./dist/utils/wcagUtils.d.ts",
      "import": "./dist/utils/wcagUtils.js"
    }
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.14.3",
    "classnames": "2.5.1",
    "css-mediaquery": "0.1.2",
    "lodash": "4.18.1",
    "stylis": "4.4.0",
    "stylis-plugin-rtl": "2.1.1"
  },
  "peerDependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/noto-sans": "5.2.10",
    "@fontsource/noto-sans-arabic": "5.2.10",
    "@fontsource/noto-sans-jp": "5.2.9",
    "@fontsource/noto-sans-thai": "5.2.8",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/system": "9.0.1",
    "@mui/utils": "9.0.1",
    "moment": "2.30.x",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-intl": "10.1.9"
  },
  "peerDependenciesMeta": {
    "moment": {
      "optional": true
    },
    "@fontsource/noto-sans": {
      "optional": true
    },
    "@fontsource/noto-sans-arabic": {
      "optional": true
    },
    "@fontsource/noto-sans-jp": {
      "optional": true
    },
    "@fontsource/noto-sans-thai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/system": "9.0.1",
    "@mui/utils": "9.0.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/css-mediaquery": "0.1.4",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/stylis": "^4.2.7",
    "@vitejs/plugin-react": "6.0.2",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "moment": "2.30.1",
    "ts-jest": "29.4.11",
    "vite": "8.0.14"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "vite build && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "publish": "npm publish --access public",
    "test": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:watch": "jest --config jest.config.cjs --watch"
  }
}
